# Anthropic API (optional, only if you use the Anthropic provider)
# Get your key at https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_KEY=sk-ant-your-key-here
VITE_NVIDIA_API_KEY=nvapi-your-key-here

# Server-side proxy (server.js)
# These stay on the server and are NEVER sent to the browser
ANTHROPIC_KEY=sk-ant-your-key-here
PORT=3001

# Default Azure DevOps workspace for no-login mode
# The PAT stays server-side and is never sent to the browser.
ADO_ORG=https://dev.azure.com/Nucor-NBT
ADO_PROJECT=NextGen
ADO_PAT=replace-with-server-side-personal-access-token

# Microsoft Entra sign-in for Azure DevOps (optional, disabled from the main UI)
# Keep these only if you want to re-enable per-user Microsoft auth later.
ADO_AUTH_CLIENT_ID=00000000-0000-0000-0000-000000000000
ADO_AUTH_CLIENT_SECRET=optional-confidential-client-secret
ADO_AUTH_TENANT_ID=organizations
ADO_AUTH_REDIRECT_URI=http://localhost:3001/api/ado-auth/callback
ADO_AUTH_SCOPE=openid profile email offline_access 499b84ac-1321-427f-aa17-267ca6975798/.default

# Default ADO landing workspace after Microsoft sign-in
VITE_ADO_ORG=Nucor-NBT
VITE_ADO_PROJECT=NextGen

# GitHub Copilot (used as the default LLM provider)
# Authenticated at runtime via the in-app device-flow login button.
# No key needed here.

# Azure DevOps MCP server (mcp-servers/ado-mcp.mjs)
# Uses the same ADO_ORG / ADO_PROJECT / ADO_PAT values above.
