# ── Anthropic API (optional, only if you use the Anthropic provider) ────
# Get your key at https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_KEY=sk-ant-your-key-here
VITE_NVIDIA_API_KEY=nvapi-your-key-here

# ── Server-side proxy (server.js) ──────────────────────────────────────
# These stay on the server and are NEVER sent to the browser
ANTHROPIC_KEY=sk-ant-your-key-here
PORT=3001

# ── GitHub Copilot (used as the default LLM provider) ───────────────────
# Authenticated at runtime via the in-app device-flow login button.
# No key needed here — the server caches the token in copilot-token.json.

# ── Azure DevOps MCP server (mcp-servers/ado-mcp.mjs) ──────────────────
# Required for the Agent mode "ado_*" tools and for loading work items.
# Create a PAT at https://dev.azure.com/<org>/_usersSettings/tokens
# Required scopes: Work Items (Read & Write), Code (Read), Project & Team (Read)
ADO_ORG=https://dev.azure.com/your-org
ADO_PROJECT=YourProject
ADO_PAT=replace-with-your-personal-access-token
