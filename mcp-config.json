{
  "$comment": "QAHub MCP server registry. Each entry is spawned as a stdio child by server.js. Disable a server by setting enabled:false. Set ADO_PAT and ADO_ORG/ADO_PROJECT in .env to enable the bundled ado-mcp.",
  "servers": {
    "filesystem": {
      "enabled": true,
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "C:\\QAHub"]
    },
    "ado": {
      "enabled": true,
      "command": "node",
      "args": ["./mcp-servers/ado-mcp.mjs"]
    },
    "git": {
      "enabled": false,
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "C:\\QAHub"]
    },
    "fetch": {
      "enabled": false,
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "playwright": {
      "enabled": false,
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
